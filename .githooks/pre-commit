#!/usr/bin/env bash
set -euo pipefail

# Get staged Python files (excluding deleted files)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.py')

if [ -z "$STAGED_PY_FILES" ]; then
    exit 0
fi

echo "Running ruff format on staged files..."
uv run ruff format $STAGED_PY_FILES

echo "Running ruff check on staged files..."
uv run ruff check --fix $STAGED_PY_FILES

# Re-stage any files that were modified by formatting/linting
git add $STAGED_PY_FILES
